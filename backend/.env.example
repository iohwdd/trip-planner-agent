DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
USE_MYSQL=false
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=trip_assistant
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_UNIX_SOCKET=/tmp/mysql.sock
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
# Redis is used for provider cache plus transient auth/session state.
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.qq.com
DJANGO_EMAIL_PORT=465
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=false
DJANGO_EMAIL_USE_SSL=true
DJANGO_EMAIL_TIMEOUT_SECONDS=15
DJANGO_DEFAULT_FROM_EMAIL=

TRIP_PLANNER_DEFAULT_CITY=
TRIP_PLANNER_REQUEST_TIMEOUT_SECONDS=60
TRIP_PLANNER_MAX_RETRIES=2
TRIP_PLANNER_CACHE_TTL_SECONDS=300
TRIP_PLANNER_RATE_LIMIT_SECONDS=0.2
TRIP_PLANNER_INLINE_JOBS=true
TRIP_PLANNER_JOB_TIMEOUT_SECONDS=90
TRIP_PLANNER_AUTH_CODE_TTL_SECONDS=600
TRIP_PLANNER_AUTH_CODE_INTERVAL_SECONDS=60
TRIP_PLANNER_AUTH_CODE_MAX_PER_WINDOW=5
TRIP_PLANNER_AUTH_CODE_MAX_PER_IP_WINDOW=10
TRIP_PLANNER_AUTH_CODE_WINDOW_SECONDS=3600
TRIP_PLANNER_AUTH_CODE_MAX_VERIFY_ATTEMPTS=5
TRIP_PLANNER_EXPOSE_DEBUG_AUTH_CODE=false
JWT_ACCESS_TOKEN_MINUTES=120
JWT_REFRESH_TOKEN_DAYS=14

DASHSCOPE_API_KEY=
QWEN_MODEL=qwen3.5-plus
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_TEMPERATURE=0.3
QWEN_ENABLE_THINKING=false

AMAP_API_KEY=
AMAP_TEXT_SEARCH_URL=https://restapi.amap.com/v5/place/text
# Amap directions reuse the same AMAP_API_KEY. No extra route endpoint config is required.

BAIDU_MAPS_API_KEY=
BAIDU_PLACE_SEARCH_URL=https://api.map.baidu.com/place/v2/search
